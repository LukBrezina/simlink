<%# locals: token, mcp_url %>
<%
  url_with_token = "#{mcp_url}/#{token.token}"
  claude_cmd = %(claude mcp add --transport http sms "#{url_with_token}")
  json_config = JSON.pretty_generate(
    "mcpServers" => {
      "sms" => {
        "type" => "http",
        "url" => mcp_url,
        "headers" => { "Authorization" => "Bearer #{token.token}" }
      }
    }
  )
%>
<div class="rounded-xl border border-gray-200 bg-white p-4">
  <details open class="group">
    <summary class="cursor-pointer list-none flex items-center justify-between">
      <div>
        <p class="font-medium"><%= token.name %></p>
        <p class="text-xs text-gray-400">
          SIM: <%= token.sim_card.display_name %> ·
          <%= token.last_used_at ? "last used #{time_ago_in_words(token.last_used_at)} ago" : "never used" %>
        </p>
      </div>
      <span class="text-gray-300 group-open:rotate-180 transition">▾</span>
    </summary>

    <div class="mt-4 space-y-4">
      <div>
        <p class="text-sm font-semibold mb-1">Option A — URL only (paste into ChatGPT connectors, etc.)</p>
        <p class="text-xs text-gray-400 mb-2">The token is in the URL. Simplest; use for clients that don't let you set headers.</p>
        <%= render "shared/copy_field", label: "MCP server URL", value: url_with_token %>
      </div>

      <div>
        <p class="text-sm font-semibold mb-1">Option B — URL + Authorization header (more secure)</p>
        <%= render "shared/copy_field", label: "URL", value: mcp_url %>
        <%= render "shared/copy_field", label: "Header", value: "Authorization: Bearer #{token.token}" %>
      </div>

      <div>
        <p class="text-sm font-semibold mb-1">Claude Code (one command)</p>
        <%= render "shared/copy_field", label: "Terminal", value: claude_cmd %>
      </div>

      <div>
        <p class="text-sm font-semibold mb-1">JSON config (Claude Desktop / generic MCP client)</p>
        <%= render "shared/copy_field", label: "mcp config", value: json_config, multiline: true %>
      </div>

      <div class="pt-2 border-t border-gray-100">
        <%= button_to "Revoke this token", mcp_token_path(token), method: :delete,
              form: { data: { turbo_confirm: "Revoke #{token.name}? Agents using it will stop working." } },
              class: "text-sm text-red-600 hover:text-red-800 cursor-pointer" %>
      </div>
    </div>
  </details>
</div>
