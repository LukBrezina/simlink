<% content_for :title, "Connect an agent" %>

<h1 class="text-2xl font-bold mb-1">Connect an agent</h1>
<p class="text-gray-500 text-sm mb-6">Create a token, then paste the MCP URL into ChatGPT, Claude, or any MCP-capable agent.</p>

<% if @shared_sims.empty? %>
  <div class="rounded-xl border border-dashed border-gray-300 p-8 text-center">
    <p class="text-gray-600 mb-2 font-medium">Share a SIM first</p>
    <p class="text-sm text-gray-400 mb-4">Agents send & receive on a SIM you've shared.</p>
    <%= link_to "Choose a SIM", sim_cards_path, class: "inline-block rounded-lg bg-blue-600 text-white font-medium px-4 py-2" %>
  </div>
<% else %>
  <!-- New token highlight -->
  <% if @new_token %>
    <div class="rounded-xl border-2 border-green-300 bg-green-50 p-4 mb-6">
      <p class="font-semibold text-green-800 mb-1">New token created 🎉</p>
      <p class="text-sm text-green-700 mb-3">Copy it now. For your security it's shown here, but treat it like a password.</p>
      <%= render "shared/copy_field", label: "MCP token", value: @new_token %>
    </div>
  <% end %>

  <!-- Create token form -->
  <div class="rounded-xl border border-gray-200 bg-white p-4 mb-8">
    <p class="font-semibold mb-3">New agent token</p>
    <%= form_with url: mcp_tokens_path, method: :post, class: "space-y-3" do |f| %>
      <div>
        <%= f.label :name, "Name (which agent is this for?)", class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :name, placeholder: "e.g. ChatGPT, Claude, my automation",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-blue-600" %>
      </div>
      <div>
        <%= f.label :sim_card_id, "SIM", class: "block text-sm font-medium mb-1" %>
        <%= f.select :sim_card_id, @shared_sims.map { |s| [s.display_name, s.id] },
              {}, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 bg-white" %>
      </div>
      <%= f.submit "Create token",
            class: "w-full rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-medium px-4 py-2.5 cursor-pointer" %>
    <% end %>
  </div>

  <!-- Existing tokens -->
  <h2 class="font-semibold mb-3">Your tokens & connection details</h2>
  <% if @tokens.any? %>
    <div class="space-y-4">
      <% @tokens.each do |token| %>
        <%= render "mcp_tokens/connection", token: token, mcp_url: @mcp_url %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-400">No tokens yet — create one above.</p>
  <% end %>

  <div class="mt-8 rounded-xl bg-gray-100 p-4 text-sm text-gray-600">
    <p class="font-semibold mb-1">What the agent can do</p>
    <ul class="list-disc list-inside space-y-1">
      <li><code class="text-xs bg-white px-1 rounded">send_sms</code> — send a text from your shared SIM</li>
      <li><code class="text-xs bg-white px-1 rounded">list_messages</code> — read recent sent/received texts</li>
      <li><code class="text-xs bg-white px-1 rounded">wait_for_sms</code> — block until a new text arrives (push-style)</li>
    </ul>
  </div>
<% end %>
