<% content_for :title, "Get SimLink" %>

<div class="text-center mt-6 mb-8">
  <div class="mx-auto w-16 h-16 rounded-2xl bg-blue-600 flex items-center justify-center mb-4">
    <span class="text-white text-2xl">💬</span>
  </div>
  <h1 class="text-2xl font-bold mb-1">SimLink</h1>
  <p class="text-gray-500 text-sm">Give your AI agents the power to send & receive SMS through your phone.</p>
</div>

<!-- Download -->
<a href="/simlink.apk" download
   class="block text-center rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-semibold px-4 py-3.5 mb-2">
  ⬇ Download the Android app (.apk)
</a>
<p class="text-center text-xs text-gray-400 mb-8">
  Android only · sideloaded · ~18&nbsp;MB. iOS can't send SMS, so there's no iOS app.
</p>

<!-- Steps -->
<ol class="space-y-3 mb-8">
  <%= render "downloads/step", n: 1, title: "Install on your Android phone",
        body: "Open the downloaded file and allow installing from this source if prompted." %>
  <%= render "downloads/step", n: 2, title: "Open SimLink & sign in",
        body: "Create your account (or sign in) right in the app." %>
  <%= render "downloads/step", n: 3, title: "Connect your phone & grant permissions",
        body: "Tap “Connect phone” and allow SMS + phone permissions so SimLink can text on your behalf." %>
  <%= render "downloads/step", n: 4, title: "Share a SIM & connect an agent",
        body: "Pick the SIM to share, create a token, and paste the MCP URL into ChatGPT, Claude, or any agent." %>
</ol>

<div class="rounded-xl bg-amber-50 border border-amber-200 p-3 text-sm text-amber-800 mb-8">
  <strong>Heads up:</strong> sending automated texts from a personal SIM can be rate-limited by your
  carrier. Keep volumes low. Texts are sent from <em>your</em> number.
</div>

<p class="text-center text-sm text-gray-500">
  Already installed? Open the SimLink app to continue. ·
  <%= link_to "Manage account", new_session_path, class: "text-blue-700 underline" %>
</p>
