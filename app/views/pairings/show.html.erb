<% content_for :title, "Connect phone" %>

<h1 class="text-2xl font-bold mb-1">Connect your phone</h1>

<% unless hotwire_native_app? %>
  <!-- Browser visitor: pairing only works inside the app -->
  <p class="text-gray-500 text-sm mb-6">Pairing happens inside the SimLink app on the phone you want to text from.</p>

  <div class="rounded-xl border border-blue-200 bg-blue-50 p-4 mb-6">
    <p class="font-medium mb-1">Continue on your Android phone</p>
    <ol class="text-sm text-gray-600 list-decimal list-inside space-y-1">
      <li><%= link_to "Get the SimLink app", get_app_path, class: "text-blue-700 underline" %> and install it.</li>
      <li>Open the app and sign in with this account.</li>
      <li>Come back to this screen <em>in the app</em> and tap “Connect phone”.</li>
    </ol>
  </div>

  <%= link_to "Get the app", get_app_path,
        class: "block text-center rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-medium px-4 py-2.5" %>
<% else %>
  <!-- Inside the app: do the real pairing -->
  <p class="text-gray-500 text-sm mb-6">This lets SimLink send & receive SMS in the background for your agents.</p>

  <% if @connected_token %>
    <div data-controller="bridge--device"
         data-bridge--device-token-value="<%= @connected_token %>"
         data-bridge--device-name-value="My phone"
         class="rounded-xl border-2 border-green-300 bg-green-50 p-4 mb-6">
      <p class="font-semibold text-green-800">Phone connected ✓</p>
      <p class="text-sm text-green-700">SimLink can now text on your behalf. Next, share a SIM.</p>
    </div>
  <% end %>

  <div class="rounded-xl border border-gray-200 bg-white p-4 mb-6">
    <div class="flex items-center gap-3 mb-3">
      <span class="inline-block w-2.5 h-2.5 rounded-full <%= @device&.last_seen_at && @device.last_seen_at > 2.minutes.ago ? 'bg-green-500' : 'bg-gray-300' %>"></span>
      <div>
        <p class="font-medium"><%= @device&.name || "This phone" %></p>
        <p class="text-xs text-gray-400">
          <%= @device&.last_seen_at ? "Last seen #{time_ago_in_words(@device.last_seen_at)} ago" : "Not connected yet" %>
        </p>
      </div>
    </div>
    <%= button_to (@device ? "Reconnect" : "Connect phone"),
          pairing_path, method: :post,
          class: "w-full rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-medium px-4 py-2.5 cursor-pointer" %>
  </div>

  <div class="rounded-xl bg-gray-100 p-4 text-sm text-gray-600">
    <p class="font-semibold mb-1">After connecting</p>
    <ol class="list-decimal list-inside space-y-1">
      <li>Grant SMS &amp; phone permissions when asked.</li>
      <li><%= link_to "Share a SIM", sim_cards_path, class: "text-blue-700 underline" %>.</li>
      <li><%= link_to "Connect an agent", setup_path, class: "text-blue-700 underline" %>.</li>
    </ol>
  </div>
<% end %>
