<% if alert = flash[:alert] %>
  <div class="mb-4 py-2 px-3 rounded-lg bg-red-50 text-red-700 text-sm font-medium" id="alert"><%= alert %></div>
<% end %>
<% if notice = flash[:notice] %>
  <div class="mb-4 py-2 px-3 rounded-lg bg-green-50 text-green-700 text-sm font-medium" id="notice"><%= notice %></div>
<% end %>
