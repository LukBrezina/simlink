<li class="rounded-xl border border-gray-200 bg-white p-4 flex items-start gap-3">
  <span class="flex-none w-7 h-7 rounded-full flex items-center justify-center text-sm font-semibold
               <%= done ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700' %>">
    <%= done ? "✓" : number %>
  </span>
  <div class="flex-1 min-w-0">
    <p class="font-medium"><%= title %></p>
    <p class="text-sm text-gray-500 truncate"><%= body %></p>
  </div>
  <%= link_to link_text, link_path, class: "flex-none text-sm text-blue-700 font-medium whitespace-nowrap" %>
</li>
