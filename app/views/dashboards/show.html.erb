<% content_for :title, "Home" %>

<%
  phone_online = @device&.last_seen_at && @device.last_seen_at > 2.minutes.ago
  step1_done = @device.present?
  step2_done = @shared_sims.any?
  step3_done = @tokens.any?
%>

<h1 class="text-2xl font-bold mb-1">Your SMS hub</h1>
<p class="text-gray-500 text-sm mb-6">Let any AI agent send and receive texts through your phone.</p>

<% if !hotwire_native_app? && !step1_done %>
  <!-- Browser visitor without a connected phone: point them to the app -->
  <div class="rounded-xl border-2 border-primary/20 bg-primary/5 p-4 mb-6 flex items-center justify-between gap-3">
    <div class="min-w-0">
      <p class="font-medium">Get the SimLink app</p>
      <p class="text-sm text-gray-600">SMS happens on your phone. Install the app to connect.</p>
    </div>
    <%= link_to "Download", get_app_path, class: "flex-none rounded-lg bg-primary hover:bg-primary-light text-white text-sm font-medium px-3.5 py-2" %>
  </div>
<% end %>

<!-- Phone status -->
<div class="rounded-xl border border-gray-200 bg-white p-4 mb-6 flex items-center justify-between">
  <div class="flex items-center gap-3">
    <span class="inline-block w-2.5 h-2.5 rounded-full <%= phone_online ? 'bg-green-500' : 'bg-gray-300' %>"></span>
    <div>
      <p class="font-medium"><%= @device&.name || "No phone connected" %></p>
      <p class="text-xs text-gray-400">
        <% if @device&.last_seen_at %>
          <%= phone_online ? "Online" : "Last seen #{time_ago_in_words(@device.last_seen_at)} ago" %>
        <% else %>
          Connect the Android app to begin
        <% end %>
      </p>
    </div>
  </div>
  <%= link_to (step1_done ? "Manage" : "Connect"), pairing_path, class: "text-sm text-primary font-medium" %>
</div>

<!-- Setup steps -->
<ol class="space-y-3 mb-8">
  <%= render "dashboards/step", number: 1, done: step1_done,
        title: "Connect your phone",
        body: "Pair the Android app so it can send & receive on your behalf.",
        link_text: step1_done ? "Reconnect" : "Connect phone", link_path: pairing_path %>
  <%= render "dashboards/step", number: 2, done: step2_done,
        title: "Share a SIM",
        body: step2_done ? "Sharing: #{@shared_sims.map(&:display_name).to_sentence}" : "Pick which SIM agents may use.",
        link_text: "Choose SIM", link_path: sim_cards_path %>
  <%= render "dashboards/step", number: 3, done: step3_done,
        title: "Connect an agent",
        body: step3_done ? "#{pluralize(@tokens.size, 'active token')}" : "Create a token and paste the MCP URL into your agent.",
        link_text: "Set up MCP", link_path: setup_path %>
</ol>

<!-- Recent messages -->
<div class="flex items-center justify-between mb-2">
  <h2 class="font-semibold">Recent messages</h2>
  <%= link_to "View all", messages_path, class: "text-sm text-primary" %>
</div>
<div class="rounded-xl border border-gray-200 bg-white divide-y divide-gray-100">
  <% if @recent_messages.any? %>
    <% @recent_messages.each do |m| %>
      <%= render "messages/row", message: m %>
    <% end %>
  <% else %>
    <p class="p-4 text-sm text-gray-400">No messages yet.</p>
  <% end %>
</div>
