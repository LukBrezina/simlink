<!DOCTYPE html>
<html class="h-full bg-cream">
  <head>
    <title><%= content_for(:title) || "SimLink by Snáz.cz" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="SimLink">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#1a5f4a">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="canonical" href="<%= "#{request.base_url}#{request.path}" %>">
    <link rel="alternate" type="text/plain" title="LLM-readable summary" href="/llms.txt">
    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" sizes="48x48">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png" sizes="512x512">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="<%= pwa_manifest_path(format: :json) %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full text-gray-900 antialiased">
    <% if authenticated? %>
      <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-gray-200">
        <div class="mx-auto max-w-2xl px-4 h-14 flex items-center justify-between">
          <%= link_to root_path, class: "font-bold text-primary flex items-baseline gap-2" do %>
            <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary self-center"></span>
            <span>SimLink</span>
            <span class="font-normal text-xs text-gray-400">by Snáz.cz</span>
          <% end %>
          <nav class="flex items-center gap-4 text-sm">
            <%= link_to "Home", root_path, class: "text-gray-600 hover:text-gray-900" %>
            <%= link_to "Messages", messages_path, class: "text-gray-600 hover:text-gray-900" %>
            <%= link_to "Connect", setup_path, class: "text-gray-600 hover:text-gray-900" %>
            <%= button_to "Sign out", session_path, method: :delete, class: "text-gray-400 hover:text-red-600 cursor-pointer" %>
          </nav>
        </div>
      </header>
    <% end %>

    <% landing = (controller_name == "pages" && action_name == "home") %>
    <% if landing %>
      <main class="lp">
        <div class="lp-container"><%= render "shared/flash" %></div>
        <%= yield %>
      </main>
    <% else %>
      <main class="mx-auto max-w-2xl px-4 py-6">
        <%= render "shared/flash" %>
        <%= yield %>
      </main>

      <footer class="mx-auto max-w-2xl px-4 py-8 text-center text-xs text-gray-400">
        SimLink — SMS for AI agents · by <span class="text-primary font-medium">Snáz.cz</span>
      </footer>
    <% end %>
  </body>
</html>
