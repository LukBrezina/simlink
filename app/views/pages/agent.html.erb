<%
  mcp_url = "#{request.base_url}/mcp"
  token_url = "#{mcp_url}/<MCP_TOKEN>"
  json_config = JSON.pretty_generate(
    "mcpServers" => { "sms" => { "type" => "http", "url" => mcp_url,
                                 "headers" => { "Authorization" => "Bearer <MCP_TOKEN>" } } }
  )
  snippet =
    case @agent[:method]
    when :command then %(claude mcp add --transport http sms "#{token_url}")
    when :url     then token_url
    else               json_config
    end
%>

<% content_for :title, "Connect #{@agent[:name]} to SimLink — SMS for AI agents" %>
<% content_for :head do %>
  <meta name="description" content="Connect <%= @agent[:name] %> to SimLink and give it a real phone number to send and receive SMS. <%= @agent[:blurb] %>">
<% end %>

<!-- Brand -->
<div class="text-center pt-4">
  <%= link_to root_path, class: "font-bold text-primary inline-flex items-baseline gap-2" do %>
    <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary self-center"></span>
    SimLink <span class="font-normal text-xs text-gray-400">by Snáz.cz</span>
  <% end %>
</div>

<section class="text-center pt-8 pb-8">
  <span class="hero-badge mb-5">📱 SMS for AI agents</span>
  <h1 class="text-4xl mb-3">Connect <%= @agent[:name] %></h1>
  <p class="text-gray-600 max-w-md mx-auto">
    Give <%= @agent[:name] %> its own phone number — let it send and receive SMS through your shared SIM.
    <%= @agent[:blurb] %>
  </p>
</section>

<ol class="space-y-4 mb-8">
  <li class="rounded-xl border border-gray-200 bg-white p-4">
    <div class="flex items-center gap-3 mb-1">
      <div class="w-7 h-7 rounded-full bg-primary text-white text-sm font-bold flex items-center justify-center">1</div>
      <p class="font-medium">Get the app &amp; a token</p>
    </div>
    <p class="text-sm text-gray-500">
      <%= link_to "Install SimLink", get_app_path, class: "text-primary font-medium" %> on an old Android phone,
      sign in, share a SIM, then create an MCP token on the setup screen.
    </p>
  </li>

  <li class="rounded-xl border border-gray-200 bg-white p-4">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-7 h-7 rounded-full bg-primary text-white text-sm font-bold flex items-center justify-center">2</div>
      <p class="font-medium">Add SimLink to <%= @agent[:name] %></p>
    </div>
    <p class="text-sm text-gray-500 mb-2">Use your token in place of <code>&lt;MCP_TOKEN&gt;</code>:</p>
    <pre class="text-xs bg-gray-900 text-gray-100 rounded-lg p-3 overflow-x-auto whitespace-pre-wrap break-words"><%= snippet %></pre>
  </li>

  <li class="rounded-xl border border-gray-200 bg-white p-4">
    <div class="flex items-center gap-3 mb-1">
      <div class="w-7 h-7 rounded-full bg-primary text-white text-sm font-bold flex items-center justify-center">3</div>
      <p class="font-medium">Text away</p>
    </div>
    <p class="text-sm text-gray-500">
      <%= @agent[:name] %> now has three tools:
      <code>send_sms</code>, <code>list_messages</code>, and <code>fetch_sms</code> — all on your shared SIM.
    </p>
  </li>
</ol>

<div class="text-center mb-8">
  <%= link_to "Get started", get_app_path, class: "btn btn-primary" %>
</div>

<p class="text-center text-sm">
  <%= link_to "← All agents", root_path(anchor: "works-with"), class: "text-primary" %>
</p>
