<% content_for :title, "SimLink — a phone number for your AI agent" %>

<% content_for :head do %>
  <meta name="description" content="Give your AI agent its own phone number. SimLink turns an old Android phone + a prepaid SIM into an SMS line your agent sends and receives from — over MCP (Claude, ChatGPT, Cursor, Hermes, and more).">
  <meta property="og:title" content="SimLink — a phone number for your AI agent">
  <meta property="og:description" content="An old Android phone + a prepaid SIM = a dedicated SMS number your AI agent can text from. Connect any MCP client.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta name="twitter:card" content="summary">
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "SimLink",
      "alternateName": "SimLink — SMS for AI agents",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Android, Web",
      "description": "A hosted MCP server that lets an AI agent send and receive SMS through a real phone/SIM the user controls.",
      "featureList": [
        "Send SMS from a real phone number over MCP (send_sms)",
        "Receive and read SMS over MCP (fetch_sms, list_messages)",
        "Works with any MCP client (Claude, ChatGPT, Cursor, and more)",
        "Encrypted in transit, never logged, pruned within minutes"
      ],
      "keywords": "MCP, SMS, AI agent, phone number, Android, Claude, ChatGPT",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "url": request.base_url
    }.to_json) %>
  </script>
<% end %>

<!-- Brand -->
<div class="text-center pt-4">
  <span class="font-bold text-primary inline-flex items-baseline gap-2">
    <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary self-center"></span>
    SimLink <span class="font-normal text-xs text-gray-400">by Snáz.cz</span>
  </span>
</div>

<!-- Hero -->
<section class="text-center pt-10 pb-10">
  <span class="hero-badge mb-6">📱 SMS for AI agents</span>
  <h1 class="text-4xl mb-4">A phone number<br>for your AI agent.</h1>
  <p class="text-gray-600 text-lg max-w-lg mx-auto mb-8">
    Drop a <strong>prepaid SIM</strong> into that <strong>old Android phone</strong> in your drawer,
    share it with SimLink, and your agent can send &amp; receive real SMS — from its own dedicated number.
  </p>
  <div class="flex flex-col sm:flex-row gap-3 justify-center">
    <%= link_to "Get the Android app", get_app_path, class: "btn btn-primary" %>
    <%= link_to "Sign in", new_session_path, class: "btn btn-secondary" %>
  </div>
  <p class="text-sm text-gray-400 mt-4">
    New here? <%= link_to "Create an account", new_registration_path, class: "text-primary font-medium" %>.
  </p>
</section>

<!-- Why -->
<section class="grid grid-cols-2 sm:grid-cols-4 gap-3 pb-10 text-center">
  <% [
    ["📟", "A real number", "Texts come from your actual SIM, not a shortcode."],
    ["♻️", "Reuse an old phone", "Any spare Android becomes the relay."],
    ["🪙", "Costs pennies", "Prepaid SIM, your normal SMS rates."],
    ["🔒", "Private", "Encrypted in transit, never logged, pruned within minutes."]
  ].each do |emoji, title, body| %>
    <div class="rounded-xl border border-gray-200 bg-white p-3">
      <div class="text-2xl mb-1"><%= emoji %></div>
      <p class="font-medium text-sm"><%= title %></p>
      <p class="text-xs text-gray-500 mt-0.5"><%= body %></p>
    </div>
  <% end %>
</section>

<!-- How it works -->
<section class="pb-10">
  <p class="section-label justify-center mb-6">How it works</p>
  <ol class="grid gap-3 sm:grid-cols-3">
    <% [
      ["Install &amp; share a SIM", "Install the app on the old phone, sign in, pick the SIM your agent may use."],
      ["Connect your agent", "Paste the MCP URL + token into Claude, ChatGPT, Cursor — any MCP client."],
      ["Text away", "Your agent calls <code>send_sms</code> / <code>fetch_sms</code> — texts go through your number."]
    ].each_with_index do |(title, body), i| %>
      <li class="rounded-xl border border-gray-200 bg-white p-4">
        <div class="w-7 h-7 rounded-full bg-primary text-white text-sm font-bold flex items-center justify-center mb-2"><%= i + 1 %></div>
        <p class="font-medium mb-1"><%= title.html_safe %></p>
        <p class="text-sm text-gray-500"><%= body.html_safe %></p>
      </li>
    <% end %>
  </ol>
</section>

<!-- Run it your way -->
<section class="pb-10">
  <p class="section-label justify-center mb-6">Choose how to run the server</p>
  <div class="grid gap-3 sm:grid-cols-2">
    <div class="rounded-xl border border-gray-200 bg-white p-5 flex flex-col">
      <p class="font-medium mb-1">☁️ Use this hosted service</p>
      <p class="text-sm text-gray-500 flex-1">
        Create an account on this instance and connect your phone in minutes — we run the
        server. Messages are encrypted in transit, never logged, and pruned within minutes.
      </p>
      <%= link_to "Create an account", new_registration_path, class: "btn btn-primary mt-4" %>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5 flex flex-col">
      <p class="font-medium mb-1">🖥️ Self-host on your own VPS</p>
      <p class="text-sm text-gray-500 flex-1">
        Want full control? It's open source — run the whole SimLink server yourself on your
        own VPS with Kamal (your domain, your database). Then point the app at it and download.
      </p>
      <%= link_to "View on GitHub", "https://github.com/LukBrezina/simlink",
            class: "btn btn-secondary mt-4", target: "_blank", rel: "noopener" %>
    </div>
  </div>
</section>

<!-- Works with -->
<section id="works-with" class="pb-10 text-center">
  <p class="section-label justify-center mb-4">Works with any MCP agent</p>
  <div class="flex flex-wrap gap-2 justify-center">
    <% @agents.each do |slug, a| %>
      <%= link_to a[:name], agent_guide_path(slug),
            class: "rounded-full border border-gray-200 bg-white px-4 py-1.5 text-sm hover:border-primary hover:text-primary transition" %>
    <% end %>
  </div>
  <p class="text-xs text-gray-400 mt-4">
    Building an agent? Read the <%= link_to "machine-readable summary", "/llms.txt", class: "text-primary" %>
    or point any MCP client at <code class="text-gray-600"><%= "#{request.base_url}/mcp" %></code>.
  </p>
</section>

<!-- Trust -->
<p class="text-center text-sm text-gray-500 rounded-xl bg-primary/5 border border-primary/20 px-4 py-3">
  🔒 Message content is <strong>encrypted in transit</strong> — never logged, pruned within minutes. Your SIM, your number, your control.
</p>
