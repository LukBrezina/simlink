<% content_for :title, "SimLink — SMS for AI agents, over MCP" %>

<% content_for :head do %>
  <meta name="description" content="A small, self-hostable server that gives an AI agent a real phone number. SimLink relays SMS through an old Android phone + a prepaid SIM you control, over MCP (Claude, ChatGPT, Cursor, and more).">
  <meta property="og:title" content="SimLink — SMS for AI agents, over MCP">
  <meta property="og:description" content="An old Android phone + a prepaid SIM = a dedicated SMS number your AI agent can send and receive from. Open source. Connect any MCP client.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta name="twitter:card" content="summary">
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "SimLink",
      "alternateName": "SimLink — SMS for AI agents",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Android, Web",
      "description": "A hosted MCP server that lets an AI agent send and receive SMS through a real phone/SIM the user controls.",
      "featureList": [
        "Send SMS from a real phone number over MCP (send_sms)",
        "Receive and read SMS over MCP (fetch_sms, list_messages)",
        "Works with any MCP client (Claude, ChatGPT, Cursor, and more)",
        "Encrypted in transit, never logged, pruned within minutes"
      ],
      "keywords": "MCP, SMS, AI agent, phone number, Android, Claude, ChatGPT",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "url": request.base_url
    }.to_json) %>
  </script>
<% end %>

<%# Brand mark reused inline — the green square + cream bubble + amber dot %>
<% brand_mark = capture do %>
  <svg viewBox="0 0 512 512" aria-hidden="true">
    <rect width="512" height="512" rx="104" fill="#1a5f4a"/>
    <g fill="#faf8f5">
      <rect x="112" y="150" width="288" height="176" rx="44"/>
      <path d="M170 300 L150 376 L250 312 Z"/>
    </g>
    <circle cx="256" cy="238" r="66" fill="#e8a54b" opacity="0.16"/>
    <circle cx="256" cy="238" r="38" fill="#e8a54b"/>
  </svg>
<% end %>

<% github_url = "https://github.com/LukBrezina/simlink" %>

<%# GitHub mark, reused for every link to the source repo %>
<% github_icon = capture do %>
  <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true">
    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
  </svg>
<% end %>

<!-- ===================== TOP BAR ===================== -->
<header class="lp-nav lp-container">
  <%= link_to root_path, class: "lp-brand" do %>
    <%= brand_mark %>
    SimLink <small>by Snáz.cz</small>
  <% end %>
  <nav class="lp-navlinks">
    <%= link_to github_url, class: "lp-gh", target: "_blank", rel: "noopener" do %><%= github_icon %>GitHub<% end %>
    <%= link_to "llms.txt", "/llms.txt" %>
    <%= link_to "sign in", new_session_path, class: "signin" %>
  </nav>
</header>

<!-- ===================== INTRO ===================== -->
<section class="lp-hero lp-container">
  <p class="lp-eyebrow"><span class="lp-dot"></span> sms · mcp · your sim</p>
  <h1 class="lp-title">SMS for your agents,<br>over <em>MCP</em>.</h1>
  <p class="lp-intro">
    A small, self-hostable server that gives an AI agent a real phone number. It relays
    texts through an old <strong>Android phone</strong> and a <strong>prepaid SIM you
    control</strong> — send and receive over the Model Context Protocol. I built it for my
    own agents and put it here in case it's useful to you. It's open source.
  </p>

  <div class="lp-actions">
    <%= link_to "get the Android app", get_app_path, class: "lp-btn lp-btn-primary" %>
    <%= link_to "create an account", new_registration_path, class: "lp-btn lp-btn-ghost" %>
    <%= link_to github_url, class: "lp-btn lp-btn-text", target: "_blank", rel: "noopener" do %><%= github_icon %>read the source<% end %>
  </div>

  <!-- the real connect details, not a glossy demo -->
  <div class="lp-term">
    <div class="lp-term-bar">
      <span class="lp-term-dots"><i></i><i></i><i></i></span>
      mcp · streamable http
      <span class="live"><span class="lp-dot"></span> ready</span>
    </div>
    <pre class="lp-term-body"><span class="c"># point any MCP client at the endpoint</span>
<span class="p">$</span> <span class="u"><%= request.base_url %>/mcp</span>   <span class="c">Authorization: Bearer &lt;token&gt;</span>

<span class="c"># or, for clients that only accept a URL</span>
<span class="p">$</span> <span class="u"><%= request.base_url %>/mcp/&lt;token&gt;</span>

<span class="c"># get a token →</span> install the app, sign in, share a SIM</pre>
  </div>
</section>

<!-- ===================== ARCHITECTURE ===================== -->
<section class="lp-section lp-container">
  <p class="lp-label">how it works</p>
  <div class="lp-arch">
    <div class="lp-node">
      <span class="k">your agent</span><span class="v">any MCP client</span>
    </div>
    <div class="lp-flow"><span class="arr">→</span><span class="lab">mcp / http</span></div>
    <div class="lp-node accent">
      <span class="k">SimLink</span><span class="v">relay server</span>
    </div>
    <div class="lp-flow"><span class="arr">→</span><span class="lab">device api</span></div>
    <div class="lp-node">
      <span class="k">your phone</span><span class="v">Android app + SIM</span>
    </div>
    <div class="lp-flow"><span class="arr">→</span><span class="lab">sms</span></div>
    <div class="lp-node">
      <span class="k">anyone</span><span class="v">a real number</span>
    </div>
  </div>
  <p class="lp-note">
    Nothing in the middle stores your texts. The server holds a message only long enough to
    hand it from the agent to the phone (or back) — encrypted, never logged, pruned within minutes.
  </p>
</section>

<!-- ===================== TOOLS / API ===================== -->
<section class="lp-section lp-container">
  <p class="lp-label">mcp tools</p>
  <div class="lp-api">
    <% [
      ["send_sms", "(to, body)", "Send a text from the SIM the user shared with you."],
      ["list_messages", "(since?, limit?)", "Recently sent messages, with delivery status and any error."],
      ["fetch_sms", "(box?, since?, address?, limit?, request_id?)",
       "Read SMS already on the phone (inbox/sent). Two-step and non-blocking: start a read, then call again with the returned request_id to collect the rows."]
    ].each do |name, args, desc| %>
      <div class="lp-fn">
        <code class="sig"><b><%= name %></b><%= args %></code>
        <p><%= desc %></p>
      </div>
    <% end %>
  </div>
  <p class="lp-note">Args marked <code>?</code> are optional. Full machine-readable summary at <%= link_to "/llms.txt", "/llms.txt", class: "lp-link" %>.</p>
</section>

<!-- ===================== PROPERTIES ===================== -->
<section class="lp-section lp-container">
  <p class="lp-label">properties</p>
  <dl class="lp-spec">
    <% [
      ["transit",  "TLS between phone, server, and agent."],
      ["at rest",  "Encrypted in the database; pruned within minutes."],
      ["logs",     "Message bodies are <b>never</b> written to logs."],
      ["history",  "None — a transient relay, no browsable archive."],
      ["number",   "A real SIM number, not a shortcode that gets flagged."],
      ["hardware", "Any spare Android in a drawer + a prepaid SIM. Nothing to buy."],
      ["cost",     "Your normal per-text rate. No subscription, no per-seat fee."],
      ["source",   "Open source — audit it, or run the whole thing yourself."]
    ].each do |key, val| %>
      <div class="row">
        <dt><%= key %></dt>
        <dd><%= val.html_safe %></dd>
      </div>
    <% end %>
  </dl>
</section>

<!-- ===================== RUN IT ===================== -->
<section class="lp-section lp-container">
  <p class="lp-label">run the server</p>
  <div class="lp-run">
    <div class="lp-card feat">
      <span class="tag">hosted · easiest</span>
      <h3>Use this instance</h3>
      <p>
        Create an account here and connect a phone in minutes — I run the server. Messages are
        encrypted in transit, never logged, and pruned within minutes.
      </p>
      <%= link_to "create an account", new_registration_path, class: "lp-btn lp-btn-primary" %>
    </div>
    <div class="lp-card">
      <span class="tag">self-host · full control</span>
      <h3>Run it on your VPS</h3>
      <p>
        It's open source. Deploy the whole SimLink server yourself with Kamal — your domain,
        your database — then point the Android app at it.
      </p>
      <%= link_to github_url, class: "lp-btn lp-btn-ghost", target: "_blank", rel: "noopener" do %><%= github_icon %>read the source<% end %>
    </div>
  </div>
</section>

<!-- ===================== WORKS WITH ===================== -->
<section id="works-with" class="lp-section lp-container">
  <p class="lp-label">tested clients</p>
  <div class="lp-pills">
    <% @agents.each do |slug, a| %>
      <%= link_to a[:name], agent_guide_path(slug), class: "lp-pill" %>
    <% end %>
  </div>
  <p class="lp-note">
    Any MCP client works — these just have copy-paste guides. Building an agent? Point it at
    <span class="lp-endpoint"><%= "#{request.base_url}/mcp" %></span>
  </p>
</section>

<!-- ===================== FOOTER ===================== -->
<footer class="lp-foot lp-container">
  <span>SimLink — SMS for AI agents · by <strong>Snáz.cz</strong></span>
  <span class="links">
    <%= link_to github_url, class: "lp-gh", target: "_blank", rel: "noopener" do %><%= github_icon %>GitHub<% end %>
    <%= link_to "llms.txt", "/llms.txt" %>
  </span>
</footer>
