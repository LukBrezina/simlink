# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (but keep the example).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key


/app/assets/builds/*
!/app/assets/builds/.keep

# Android build artifacts & signing material — never commit keystores/secrets.
/android/.gradle/
/android/build/
/android/app/build/
/android/local.properties
/android/keystore.properties
/android/.idea/
*.jks
*.keystore

# Firebase service-account keys — never commit
*firebase-adminsdk*.json

# Per-project Firebase client config — each self-hoster supplies their own
# (the build seeds it from google-services.json.example if absent). Never commit
# a real one: it ties the app to your Firebase project and exposes its API key.
/android/app/google-services.json

# Published APKs are built locally and served from /get. The deploy image picks
# them up from disk (Dockerfile COPY), so they ship without being committed — and
# a committed APK would bake in your domain + Firebase key. Keep the dir, not the binaries.
/downloads/*
!/downloads/.keep
