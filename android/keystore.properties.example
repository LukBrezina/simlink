# Copy to `keystore.properties` (gitignored) for signed release builds.
#
# Create a keystore once:
#   keytool -genkey -v -keystore release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias smsforagents
#
# Keep release.jks and these passwords SAFE and BACKED UP — losing them means you
# can never update the GitHub/Obtainium build again (F-Droid uses its own key).

storeFile=release.jks
storePassword=CHANGE_ME
keyAlias=smsforagents
keyPassword=CHANGE_ME
