# Copy to `.env` (gitignored) and fill in. Kamal loads this automatically on deploy.

# --- Required ---

# Public host/domain of your deployment, host only (no https://). Used for TLS
# (kamal-proxy), the mailer link host, and — at app build time — the Android
# release BASE_URL. Example: sms.example.com
APP_HOST=

# Rails credentials key — the contents of config/master.key.
RAILS_MASTER_KEY=

# ActiveRecord encryption keys (protect the stored MCP tokens).
# Generate three fresh 32-char values:
#   bin/rails runner 'puts SecureRandom.alphanumeric(32)'   # run x3
AR_ENCRYPTION_PRIMARY_KEY=
AR_ENCRYPTION_DETERMINISTIC_KEY=
AR_ENCRYPTION_KEY_DERIVATION_SALT=

# --- Optional ---

# SSH target for Kamal. Defaults to APP_HOST. Set this when the public host isn't
# reachable on port 22 — e.g. it's Cloudflare-proxied (use the VPS origin IP) or
# you reach the box over a private network / Tailscale name.
SIMLINK_SSH_HOST=

# Container registry for the built image. Defaults to a local unauthenticated
# registry on the server (localhost:5555). Set to docker.io / ghcr.io etc. if you
# push to a hosted registry instead.
KAMAL_REGISTRY_SERVER=

# "From" address for outgoing mail (password resets). Defaults to no-reply@example.com.
MAIL_FROM=

# Firebase Cloud Messaging service-account JSON, for the content-free push that
# wakes the phone instantly. OPTIONAL — leave blank and the phone falls back to
# a periodic poll (a little slower, no Google dependency). Paste the full JSON.
FCM_SERVICE_ACCOUNT_JSON=
