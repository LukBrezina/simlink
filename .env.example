# Copy to `.env` (gitignored) and fill in. Kamal loads this automatically on deploy.

# --- Required ---

# Rails credentials key — the contents of config/master.key.
RAILS_MASTER_KEY=

# ActiveRecord encryption keys (protect the stored MCP tokens).
# Generate three fresh 32-char values:
#   bin/rails runner 'puts SecureRandom.alphanumeric(32)'   # run x3
AR_ENCRYPTION_PRIMARY_KEY=
AR_ENCRYPTION_DETERMINISTIC_KEY=
AR_ENCRYPTION_KEY_DERIVATION_SALT=

# --- Optional ---

# SSH host for Kamal when the proxy host is Cloudflare-proxied (port 22 not
# reachable). Set to the VPS origin IP; keeps it out of git. Leave blank to SSH
# straight to proxy.host.
SIMLINK_SSH_HOST=

# Firebase Cloud Messaging service-account JSON, for the content-free push that
# wakes the phone instantly. OPTIONAL — leave blank and the phone falls back to
# a periodic poll (a little slower, no Google dependency). Paste the full JSON.
FCM_SERVICE_ACCOUNT_JSON=
